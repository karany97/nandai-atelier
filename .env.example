# Atelier — operator deploy config
# Copy this file to `.env`, fill in your real values, then run:
#   bash scripts/deploy-atelier.sh
#
# `.env` is gitignored. NEVER commit it.
#
# Source code uses the sentinels __BAKED_BASE_URL__, __BAKED_API_KEY__,
# __BAKED_TOOLS_URL__ as compile-time defaults. The deploy script reads the
# env vars below and `sed`-replaces those sentinels in the built bundle.html
# before shipping it to your server.
#
# Why is this not bundled into `npm run build`? So a single artifact serves
# two purposes: a published, neutered bundle for the GitHub release (empty
# defaults — first-time visitors get pushed to Settings), and a baked
# operator-specific bundle for the production deploy.

# ─── Required for `deploy-atelier.sh` ──────────────────────────────────────

# Your LiteLLM gateway. Two modes:
#
# RECOMMENDED — Same-origin auth-proxy mode:
#   Set to a path (must start with /).  The bundle sends fetch('/api/llm/v1/*')
#   with `credentials: 'include'`, and your reverse-proxy validates the gate
#   cookie and injects the LiteLLM master key server-side. The master key
#   NEVER appears in the bundle, so the deploy is safe for fully-public use.
#   See `docs/auth-proxy.md` for the mythos-gate patch that adds this route.
#
#   Example: NANDAI_LITELLM_URL=/api/llm
#            NANDAI_LITELLM_KEY=
#
# LEGACY — Cross-origin Bearer mode:
#   Set to an absolute URL.  The bundle bakes in the API key as a default
#   and sends Authorization: Bearer <key> to that URL.  Anyone who can load
#   the bundle can read the key, so only use this behind PIN gate / SSO / IP
#   allowlist on a trusted hostname.
#
#   Example: NANDAI_LITELLM_URL=https://llm.example.com
#            NANDAI_LITELLM_KEY=sk-replace-with-your-key
NANDAI_LITELLM_URL=/api/llm
NANDAI_LITELLM_KEY=

# mcpo middleware (https://github.com/open-webui/mcpo). Leave blank to ship
# with the no-tools-loaded badge.
NANDAI_TOOLS_URL=https://tools.example.com

# ─── Required for `deploy-atelier.sh` SSH targeting ────────────────────────

# Either a hostname your machine can reach, OR an SSH alias from ~/.ssh/config.
# Tailscale hostnames work great here.
ATELIER_DEPLOY_HOST=operator@my-infra-box.local

# Optional — only set if SSH-as is gated by a specific key
ATELIER_DEPLOY_KEY=~/.ssh/id_ed25519

# Path on the deploy host where the bundle should land. The systemd unit
# `atelier-static.service` should serve from this path (the deploy script
# does `sudo cp <bundle> ${ATELIER_REMOTE_PATH}` and restarts the unit).
ATELIER_REMOTE_PATH=/srv/nandai-atelier/index.html
ATELIER_REMOTE_PORT=3057
